# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 可选：若团队统一使用 npm，可取消注释以下行以提交 lockfile
# 若使用 yarn 或 pnpm，建议提交对应的 lockfile
# package-lock.json

# --- 编辑器 / IDE ---
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
*.swp
*.swo
*~
.idea/
*.iml
.vs/

# --- OS 生成文件 ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- 环境变量 ---
.env
.env.local
.env.*.local

# --- 测试 / 校验临时输出 ---
*.tmp
*.log
mcp/dist/
mcp/src/**/*.js
mcp/tests/**/*.js
dist/

# --- 临时目录 / 生成文件 ---
.tmp/
.tmp-audit-check/
__pycache__/
*.pyc

# --- Claude Code ---
# 个人项目级设置覆盖（权限审批、本机偏好等）；团队共享请用 .claude/settings.json
.claude/settings.local.json
# 其他本地覆盖（插件设置、hookify 规则等）
.claude/*.local.json
.claude/*.local.md
# 项目根的个人 CLAUDE 偏好（与 CLAUDE.md 并列加载，不共享）
CLAUDE.local.md
# --worktree / EnterWorktree 创建的隔离工作树
.claude/worktrees/
# subagent 本机记忆（memory: local）；项目共享记忆用 .claude/agent-memory/
.claude/agent-memory-local/
