{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://internal/schema-ui/node.schema.json",
  "title": "Schema-UI Node",
  "description": "参见 docs/01-node-protocol.md，本文件是其权威机器可读版本",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "description": "组件类型标识，需存在于 component-registry.json 中"
    },
    "id": {
      "type": "string",
      "description": "【可选，since 0.2】页面内唯一标识，用于定位/埋点/增量 patch，Renderer 需校验重复"
    },
    "props": {
      "type": "object",
      "description": "业务级配置参数，禁止出现 CSS 属性名",
      "not": {
        "anyOf": [
          { "required": ["margin"] },
          { "required": ["padding"] },
          { "required": ["color"] },
          { "required": ["background"] },
          { "required": ["fontSize"] },
          { "required": ["fontWeight"] },
          { "required": ["border"] },
          { "required": ["borderRadius"] },
          { "required": ["width"] },
          { "required": ["height"] },
          { "required": ["zIndex"] },
          { "required": ["boxShadow"] },
          { "required": ["lineHeight"] },
          { "required": ["letterSpacing"] },
          { "required": ["textAlign"] }
        ]
      }
    },
    "data": {
      "$ref": "#/definitions/DataRef"
    },
    "children": {
      "type": "array",
      "items": { "$ref": "#" }
    },
    "reactions": {
      "type": "array",
      "items": { "$ref": "reaction.schema.json" }
    },
    "states": {
      "$ref": "#/definitions/StatesMap"
    }
  },
  "required": ["type"],
  "additionalProperties": false,
  "definitions": {
    "DataRef": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "enum": ["static", "ref", "api"]
        },
        "value": {},
        "ref": { "type": "string" },
        "url": { "type": "string" },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"],
          "description": "与 action.schema.json 的 method 枚举保持一致。GET/POST 覆盖常见场景，PUT/DELETE/PATCH 预留用于扩展（如编辑表单场景）"
        }
      },
      "required": ["source"],
      "allOf": [
        {
          "if": { "properties": { "source": { "const": "static" } } },
          "then": { "required": ["value"] }
        },
        {
          "if": { "properties": { "source": { "const": "ref" } } },
          "then": { "required": ["ref"] }
        },
        {
          "if": { "properties": { "source": { "const": "api" } } },
          "then": { "required": ["url"] }
        }
      ]
    },
    "StatesMap": {
      "type": "object",
      "description": "组件级空态/加载态/错误态定制（since 0.2），仅对 component-registry.json 中 supportsStates: true 的组件有效",
      "properties": {
        "loading": { "$ref": "#/definitions/StateContent" },
        "empty": { "$ref": "#/definitions/StateContent" },
        "error": { "$ref": "#/definitions/StateContent" }
      },
      "additionalProperties": false
    },
    "StateContent": {
      "type": "object",
      "description": "仅允许语义级文案/插画标识，不允许样式类字段",
      "properties": {
        "text": { "type": "string" },
        "illustration": { "type": "string" },
        "fallbackText": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
