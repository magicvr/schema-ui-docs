{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://internal/schema-ui/reaction.schema.json",
  "title": "Schema-UI Reaction",
  "description": "参见 docs/02-reaction-expression.md，本文件是其权威机器可读版本",
  "type": "object",
  "properties": {
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 0,
      "description": "依赖字段声明。scope: form（默认）下列出 when 表达式中使用的 $deps.* 表单字段；scope: row 下列出 when 表达式中使用的 $row.* 行内字段路径，不注入表单级 $deps。允为空数组（仅引用 $self 或 $context 时）"
    },
    "when": {
      "type": "string",
      "minLength": 1,
      "description": "条件表达式，语法白名单见 02-reaction-expression.md，禁止函数调用/算术运算"
    },
    "scope": {
      "type": "string",
      "enum": ["form", "row"],
      "description": "【可选，since 0.2】表达式求值作用域，form（默认）或 row"
    },
    "fulfill": { "$ref": "#/definitions/StateMap" },
    "otherwise": { "$ref": "#/definitions/StateMap" }
  },
  "required": ["dependencies", "when", "fulfill"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "scope": { "const": "row" } },
        "required": ["scope"]
      },
      "then": {
        "properties": {
          "fulfill": {
            "not": { "anyOf": [
              { "required": ["required"] },
              { "required": ["value"] }
            ]}
          },
          "otherwise": {
            "not": { "anyOf": [
              { "required": ["required"] },
              { "required": ["value"] }
            ]}
          }
        }
      }
    }
  ],
  "definitions": {
    "StateMap": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" },
        "required": { "type": "boolean" },
        "disabled": { "type": "boolean" },
        "value": {}
      },
      "additionalProperties": false,
      "description": "只允许语义级状态键，不允许组件私有 props 或样式键"
    }
  }
}
