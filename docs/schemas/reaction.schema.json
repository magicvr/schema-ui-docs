{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://internal/schema-ui/reaction.schema.json",
  "title": "Schema-UI Reaction",
  "description": "参见 docs/02-reaction-expression.md，本文件是其权威机器可读版本",
  "type": "object",
  "properties": {
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*$" },
      "minItems": 0,
      "uniqueItems": true,
      "description": "依赖字段声明。scope: form（默认）：列出 when 中 $deps.<field> 的字段名（无 $deps. 前缀，如 orderType）；scope: row：列出 when 中 $row.<path> 的 $row. 之后完整点路径（无 $row. 前缀，如 canRefund / user.id / __index），不注入表单级 $deps。未引用 $deps.* / $row.* 时可为空数组，例如仅引用 $self、$context.* 或不引用变量。不得写入带 $deps. / $row. 前缀的字符串。见 docs/02-reaction-expression.md §8.1"
    },
    "when": {
      "type": "string",
      "minLength": 1,
      "description": "条件表达式，语法白名单见 02-reaction-expression.md，禁止函数调用/算术运算"
    },
    "scope": {
      "type": "string",
      "enum": ["form", "row"],
      "description": "【可选，since 0.2】表达式求值作用域，form（默认）或 row"
    },
    "fulfill": { "$ref": "#/definitions/StateMap" },
    "otherwise": { "$ref": "#/definitions/StateMap" }
  },
  "required": ["dependencies", "when", "fulfill"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "scope": { "const": "row" } },
        "required": ["scope"]
      },
      "then": {
        "properties": {
          "fulfill": {
            "not": { "anyOf": [
              { "required": ["required"] },
              { "required": ["value"] }
            ]}
          },
          "otherwise": {
            "not": { "anyOf": [
              { "required": ["required"] },
              { "required": ["value"] }
            ]}
          }
        }
      }
    }
  ],
  "definitions": {
    "StateMap": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" },
        "required": { "type": "boolean" },
        "disabled": { "type": "boolean" },
        "value": {}
      },
      "additionalProperties": false,
      "description": "只允许语义级状态键，不允许组件私有 props 或样式键"
    }
  }
}
