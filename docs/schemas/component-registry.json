{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://internal/schema-ui/component-registry.json",
  "title": "Schema-UI Component Registry",
  "description": "组件类型注册表机器可读版本，需与 docs/03-component-registry.md 保持同步。建议由 CI 从前端组件 Props 类型定义自动生成本文件。",
  "components": {
    "grid": {
      "supportsChildren": true,
      "supportsData": false,
      "supportsStates": false,
      "props": {
        "columns": { "type": "number", "required": true }
      }
    },
    "section": {
      "supportsChildren": true,
      "supportsData": false,
      "supportsStates": false,
      "props": {
        "title": { "type": "string", "required": false },
        "titleKey": { "type": "string", "required": false },
        "span": { "type": "number", "required": false }
      }
    },
    "tabs": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsStates": false,
      "props": {
        "items": {
          "type": "array",
          "required": true,
          "description": "since 0.2：每项内嵌 content（完整 Node），不再依赖顶层 children 按 key 匹配（见方案 A，审计 §2.4）",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string", "required": true },
              "label": { "type": "string" },
              "labelKey": { "type": "string" },
              "content": { "$ref": "node.schema.json", "description": "完整 Node" }
            },
            "required": ["key"],
            "anyOf": [
              { "required": ["label"] },
              { "required": ["labelKey"] }
            ]
          }
        }
      }
    },
    "statCard": {
      "supportsChildren": false,
      "supportsData": true,
      "supportsStates": true,
      "props": {
        "label": { "type": "string", "required": false, "description": "卡片标题，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "unit": { "type": "string", "required": false },
        "format": { "type": "string", "enum": ["plain", "currency", "percent"], "required": false },
        "valueField": {
          "type": "string",
          "required": true,
          "since": "0.2",
          "description": "since 0.2：由 data.valueField 迁移而来（审计 §2.1），指定从 API 响应中取哪个字段作为展示值"
        },
        "span": { "type": "number", "required": false, "since": "0.2" }
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["labelKey"] }
      ]
    },
    "chart": {
      "supportsChildren": false,
      "supportsData": true,
      "supportsStates": true,
      "props": {
        "chartType": { "type": "string", "enum": ["line", "bar", "pie"], "required": true },
        "xField": { "type": "string", "required": true },
        "yField": { "type": "string", "required": true },
        "span": { "type": "number", "required": false, "since": "0.2" }
      }
    },
    "text": {
      "supportsChildren": false,
      "supportsData": true,
      "supportsStates": true,
      "props": {
        "content": { "type": "string", "required": true },
        "contentKey": { "type": "string", "required": false },
        "valueField": {
          "type": "string",
          "required": false,
          "since": "0.2",
          "description": "since 0.2：data.source 为 api 时，指定取哪个字段作为展示文本。未指定时 Renderer 默认取响应体第一个字段值（与 statCard 保持一致的取值方式，但 statCard 的 valueField 为必填，text 为可选）"
        },
        "span": { "type": "number", "required": false, "since": "0.2" }
      }
    },
    "table": {
      "supportsChildren": false,
      "supportsData": true,
      "supportsStates": true,
      "props": {
        "title": { "type": "string", "required": false },
        "rowKey": { "type": "string", "required": true },
        "pagination": {
          "type": "object",
          "required": true,
          "description": "分页配置",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["server", "client", "none"],
              "required": true,
              "description": "分页模式：server（服务端分页）/ client（客户端分页）/ none（不分页）"
            },
            "pageSize": {
              "type": "number",
              "required": false,
              "description": "默认页大小"
            }
          }
        },
        "columns": {
          "type": "array",
          "required": true,
          "description": "列定义，与 docs/03-component-registry.md 中 ColumnDef 表格保持一致",
          "items": {
            "type": "object",
            "properties": {
              "field": { "type": "string", "description": "对应数据字段名" },
              "label": { "type": "string", "description": "列标题" },
              "format": { "type": "string", "enum": ["plain", "currency", "datetime", "tag"], "description": "展示格式" },
              "tagMap": {
                "type": "object",
                "description": "format: tag 时，值 → {text, tone} 的映射",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "tone": { "type": "string" }
                  }
                }
              },
              "labelKey": { "type": "string", "description": "列标题 i18n key（since 0.2）" },
              "visibleWhen": { "$ref": "node.schema.json#/definitions/VisibleWhen", "description": "列级条件渲染（since 0.2）" },
              "reactions": { "type": "array", "items": { "$ref": "reaction.schema.json" }, "description": "列级联动规则（since 0.2）" },
              "permissions": { "$ref": "node.schema.json#/definitions/Permissions", "description": "列级权限控制（since 0.2）" }
            },
            "required": ["field"],
            "anyOf": [
              { "required": ["label"] },
              { "required": ["labelKey"] }
            ],
            "additionalProperties": false
          }
        },
        "actions": {
          "type": "array",
          "required": false,
          "description": "行内操作，每项支持 visibleField（since 0.2，审计 §3.6 过渡方案，数据驱动显隐）",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string", "required": true },
              "label": { "type": "string", "description": "操作文案，与 labelKey 至少提供一个" },
              "labelKey": { "type": "string", "description": "操作文案 i18n key，与 label 至少提供一个" },
              "confirm": { "type": "string" },
              "visibleField": {
                "type": "string",
                "since": "0.2",
                "description": "取当前行数据中的同名布尔字段作为显隐依据，不引入 $row 表达式"
              },
              "visibleWhen": { "$ref": "node.schema.json#/definitions/VisibleWhen", "description": "行级操作条件渲染（since 0.2）" },
              "reactions": { "type": "array", "items": { "$ref": "reaction.schema.json" }, "description": "行级操作联动规则（since 0.2）" },
              "permissions": { "$ref": "node.schema.json#/definitions/Permissions", "description": "行级操作权限控制（since 0.2）" }
            },
            "required": ["key"],
            "anyOf": [
              { "required": ["label"] },
              { "required": ["labelKey"] }
            ],
            "additionalProperties": false
          }
        },
        "span": { "type": "number", "required": false, "since": "0.2" }
      }
    },
    "form": {
      "supportsChildren": true,
      "supportsData": false,
      "supportsStates": false,
      "props": {
        "title": { "type": "string", "required": false },
        "titleKey": { "type": "string", "required": false },
        "submitAction": { "type": "string", "required": false, "description": "默认模式（mode=default）下必填，引用顶层 actions 中的动作 id；mode=search 时忽略此字段" },
        "mode": {
          "type": "string",
          "enum": ["default", "search"],
          "required": false,
          "since": "0.2.1",
          "description": "表单模式：default（提交动作）/ search（筛选表格）"
        },
        "targetTable": {
          "type": "string",
          "required": false,
          "since": "0.2.1",
          "description": "mode=search 时必填，关联表格的 Node id"
        }
      }
    },
    "input": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "required": true },
        "label": { "type": "string", "required": false, "description": "字段标签，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false },
        "placeholder": { "type": "string", "required": false, "since": "0.2" },
        "description": { "type": "string", "required": false, "since": "0.2" },
        "tooltip": { "type": "string", "required": false, "since": "0.2" }
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["labelKey"] }
      ]
    },
    "inputNumber": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "required": true },
        "label": { "type": "string", "required": false, "description": "字段标签，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "min": { "type": "number", "required": false, "since": "0.2.1", "description": "最小值" },
        "max": { "type": "number", "required": false, "since": "0.2.1", "description": "最大值" },
        "step": { "type": "number", "required": false, "since": "0.2.1", "description": "步长" },
        "precision": { "type": "number", "required": false, "since": "0.2.1", "description": "保留小数位数" },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false },
        "placeholder": { "type": "string", "required": false, "since": "0.2" },
        "description": { "type": "string", "required": false, "since": "0.2" },
        "tooltip": { "type": "string", "required": false, "since": "0.2" }
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["labelKey"] }
      ]
    },
    "datePicker": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "required": true },
        "label": { "type": "string", "required": false, "description": "字段标签，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "placeholder": { "type": "string", "required": false },
        "format": { "type": "string", "required": false, "description": "日期展示格式，仅控制前端展示；数据格式统一 ISO 8601" },
        "min": { "type": "string", "required": false, "description": "可选最小日期 ISO 8601" },
        "max": { "type": "string", "required": false, "description": "可选最大日期 ISO 8601" },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false }
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["labelKey"] }
      ]
    },
    "dateRangePicker": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "startField": { "type": "string", "required": true },
        "endField": { "type": "string", "required": true },
        "label": { "type": "string", "required": false, "description": "字段标签，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "placeholder": { "type": "string", "required": false },
        "min": { "type": "string", "required": false, "description": "可选最小日期 ISO 8601" },
        "max": { "type": "string", "required": false, "description": "可选最大日期 ISO 8601" },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false }
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["labelKey"] }
      ]
    },
    "upload": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "required": true },
        "label": { "type": "string", "required": false, "description": "字段标签，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "accept": { "type": "string", "required": false, "description": "接受的文件 MIME 类型" },
        "maxSize": { "type": "number", "required": false, "description": "最大文件大小（字节）" },
        "multiple": { "type": "boolean", "required": false, "description": "是否支持多文件上传" },
        "action": { "type": "string", "required": true, "description": "上传接口地址（相对路径）" },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false }
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["labelKey"] }
      ]
    },
    "select": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "required": true },
        "label": { "type": "string", "required": false, "description": "字段标签，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "options": {
          "type": "array",
          "required": false,
          "description": "与 optionsSource 二选一",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string", "description": "选项文案" },
              "value": { "description": "选项值" }
            },
            "required": ["label", "value"]
          }
        },
        "optionsSource": {
          "type": "object",
          "required": false,
          "since": "0.2",
          "description": "与 options 二选一，远程动态选项（审计 §3.4）。params 可引用 $deps.*，值为 null/undefined 时该参数整体省略",
          "properties": {
            "url": { "type": "string", "required": true },
            "params": { "type": "object", "required": false },
            "labelField": { "type": "string", "required": true },
            "valueField": { "type": "string", "required": true },
            "searchable": { "type": "boolean", "required": false }
          }
        },
        "placeholder": { "type": "string", "required": false, "since": "0.2" },
        "description": { "type": "string", "required": false, "since": "0.2" },
        "tooltip": { "type": "string", "required": false, "since": "0.2" }
      },
      "allOf": [
        {
          "anyOf": [
            { "required": ["label"] },
            { "required": ["labelKey"] }
          ]
        },
        {
          "anyOf": [
            { "required": ["options"] },
            { "required": ["optionsSource"] }
          ]
        }
      ]
    }
  }
}
