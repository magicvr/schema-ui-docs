{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://internal/schema-ui/component-registry.json",
  "description": "组件类型注册表机器可读版本，需与 docs/03-component-registry.md 保持同步。建议由 CI 从前端组件 Props 类型定义自动生成本文件。",
  "components": {
    "grid": {
      "supportsChildren": true,
      "supportsData": false,
      "supportsStates": false,
      "props": {
        "columns": { "type": "number", "required": true }
      }
    },
    "section": {
      "supportsChildren": true,
      "supportsData": false,
      "supportsStates": false,
      "props": {
        "title": { "type": "string", "required": false },
        "titleKey": { "type": "string", "required": false },
        "span": { "type": "number", "required": false }
      }
    },
    "tabs": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsStates": false,
      "props": {
        "items": {
          "type": "array",
          "required": true,
          "description": "since 0.2：每项内嵌 content（完整 Node），不再依赖顶层 children 按 key 匹配（见方案 A，审计 §2.4）",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string", "required": true },
              "label": { "type": "string" },
              "labelKey": { "type": "string" },
              "content": { "type": "object", "description": "完整 Node" }
            }
          }
        }
      }
    },
    "statCard": {
      "supportsChildren": false,
      "supportsData": true,
      "supportsStates": true,
      "props": {
        "label": { "type": "string", "required": true },
        "labelKey": { "type": "string", "required": false },
        "unit": { "type": "string", "required": false },
        "format": { "type": "string", "enum": ["plain", "currency", "percent"], "required": false },
        "valueField": {
          "type": "string",
          "required": true,
          "since": "0.2",
          "description": "since 0.2：由 data.valueField 迁移而来（审计 §2.1），指定从 API 响应中取哪个字段作为展示值"
        },
        "span": { "type": "number", "required": false, "since": "0.2" }
      }
    },
    "chart": {
      "supportsChildren": false,
      "supportsData": true,
      "supportsStates": true,
      "props": {
        "chartType": { "type": "string", "enum": ["line", "bar", "pie"], "required": true },
        "xField": { "type": "string", "required": true },
        "yField": { "type": "string", "required": true },
        "span": { "type": "number", "required": false, "since": "0.2" }
      }
    },
    "text": {
      "supportsChildren": false,
      "supportsData": true,
      "supportsStates": true,
      "props": {
        "content": { "type": "string", "required": true },
        "contentKey": { "type": "string", "required": false },
        "valueField": {
          "type": "string",
          "required": false,
          "since": "0.2",
          "description": "since 0.2：data.source 为 api 时，指定取哪个字段作为展示文本（审计 §4.3，与 statCard 保持一致的取值方式）"
        },
        "span": { "type": "number", "required": false, "since": "0.2" }
      }
    },
    "table": {
      "supportsChildren": false,
      "supportsData": true,
      "supportsStates": true,
      "props": {
        "title": { "type": "string", "required": false },
        "rowKey": { "type": "string", "required": true },
        "pagination": { "type": "object", "required": true },
        "columns": {
          "type": "array",
          "required": true,
          "description": "列定义，与 docs/03-component-registry.md 中 ColumnDef 表格保持一致",
          "items": {
            "type": "object",
            "properties": {
              "field": { "type": "string", "description": "对应数据字段名" },
              "label": { "type": "string", "description": "列标题" },
              "format": { "type": "string", "enum": ["plain", "currency", "datetime", "tag"], "description": "展示格式" },
              "tagMap": {
                "type": "object",
                "description": "format: tag 时，值 → {text, tone} 的映射",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "tone": { "type": "string" }
                  }
                }
              }
            },
            "required": ["field"],
            "additionalProperties": false
          }
        },
        "actions": {
          "type": "array",
          "required": false,
          "description": "行内操作，每项支持 visibleField（since 0.2，审计 §3.6 过渡方案，数据驱动显隐）",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string", "required": true },
              "label": { "type": "string" },
              "labelKey": { "type": "string" },
              "confirm": { "type": "string" },
              "visibleField": {
                "type": "string",
                "since": "0.2",
                "description": "取当前行数据中的同名布尔字段作为显隐依据，不引入 $row 表达式"
              }
            }
          }
        },
        "span": { "type": "number", "required": false, "since": "0.2" }
      }
    },
    "form": {
      "supportsChildren": true,
      "supportsData": false,
      "supportsStates": false,
      "props": {
        "title": { "type": "string", "required": false },
        "titleKey": { "type": "string", "required": false },
        "submitAction": { "type": "string", "required": false, "description": "默认模式下必填。mode=search 时忽略" },
        "mode": {
          "type": "string",
          "enum": ["default", "search"],
          "required": false,
          "since": "0.2.1",
          "description": "表单模式：default（提交动作）/ search（筛选表格）"
        },
        "targetTable": {
          "type": "string",
          "required": false,
          "since": "0.2.1",
          "description": "mode=search 时必填，关联表格的 Node id"
        }
      }
    },
    "input": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "required": true },
        "label": { "type": "string", "required": true },
        "labelKey": { "type": "string", "required": false },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false },
        "placeholder": { "type": "string", "required": false, "since": "0.2" },
        "description": { "type": "string", "required": false, "since": "0.2" },
        "tooltip": { "type": "string", "required": false, "since": "0.2" }
      }
    },
    "inputNumber": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "required": true },
        "label": { "type": "string", "required": true },
        "labelKey": { "type": "string", "required": false },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false },
        "placeholder": { "type": "string", "required": false, "since": "0.2" },
        "description": { "type": "string", "required": false, "since": "0.2" },
        "tooltip": { "type": "string", "required": false, "since": "0.2" }
      }
    },
    "datePicker": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "required": true },
        "label": { "type": "string", "required": true },
        "labelKey": { "type": "string", "required": false },
        "placeholder": { "type": "string", "required": false },
        "format": { "type": "string", "required": false, "description": "日期展示格式，仅控制前端展示；数据格式统一 ISO 8601" },
        "min": { "type": "string", "required": false, "description": "可选最小日期 ISO 8601" },
        "max": { "type": "string", "required": false, "description": "可选最大日期 ISO 8601" },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false }
      }
    },
    "dateRangePicker": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "startField": { "type": "string", "required": true },
        "endField": { "type": "string", "required": true },
        "label": { "type": "string", "required": true },
        "labelKey": { "type": "string", "required": false },
        "placeholder": { "type": "string", "required": false },
        "min": { "type": "string", "required": false, "description": "可选最小日期 ISO 8601" },
        "max": { "type": "string", "required": false, "description": "可选最大日期 ISO 8601" },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false }
      }
    },
    "upload": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "required": true },
        "label": { "type": "string", "required": true },
        "labelKey": { "type": "string", "required": false },
        "accept": { "type": "string", "required": false, "description": "接受的文件 MIME 类型" },
        "maxSize": { "type": "number", "required": false, "description": "最大文件大小（字节）" },
        "multiple": { "type": "boolean", "required": false, "description": "是否支持多文件上传" },
        "action": { "type": "string", "required": true, "description": "上传接口地址（相对路径）" },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false }
      }
    },
    "select": {
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "required": true },
        "label": { "type": "string", "required": true },
        "labelKey": { "type": "string", "required": false },
        "options": {
          "type": "array",
          "required": false,
          "description": "与 optionsSource 二选一"
        },
        "optionsSource": {
          "type": "object",
          "required": false,
          "since": "0.2",
          "description": "与 options 二选一，远程动态选项（审计 §3.4）。params 可引用 $deps.*，值为 null/undefined 时该参数整体省略",
          "properties": {
            "url": { "type": "string", "required": true },
            "params": { "type": "object", "required": false },
            "labelField": { "type": "string", "required": true },
            "valueField": { "type": "string", "required": true },
            "searchable": { "type": "boolean", "required": false }
          }
        },
        "placeholder": { "type": "string", "required": false, "since": "0.2" },
        "description": { "type": "string", "required": false, "since": "0.2" },
        "tooltip": { "type": "string", "required": false, "since": "0.2" }
      }
    }
  }
}
