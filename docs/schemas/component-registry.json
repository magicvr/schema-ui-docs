{
  "$schema": "https://internal/schema-ui/component-registry-dsl#",
  "$id": "https://internal/schema-ui/component-registry.json",
  "title": "Schema-UI Component Registry",
  "description": "组件类型注册表机器可读结构契约（自定义 DSL，非标准 JSON Schema）。验证器和工具必须从本文件读取组件字段、能力与分类；Markdown 仅补充语义说明。",
  "components": {
    "grid": {
      "category": "布局",
      "supportsChildren": true,
      "supportsData": false,
      "supportsReactions": false,
      "supportsStates": false,
      "props": {
        "columns": { "type": "integer", "minimum": 1, "required": true },
        "span": { "type": "integer", "minimum": 1, "required": false, "since": "0.2" },
        "additionalProperties": false
      }
    },
    "section": {
      "category": "布局",
      "supportsChildren": true,
      "supportsData": false,
      "supportsReactions": false,
      "supportsStates": false,
      "props": {
        "title": { "type": "string", "required": false },
        "titleKey": { "type": "string", "required": false },
        "span": { "type": "integer", "minimum": 1, "required": false },
        "additionalProperties": false
      }
    },
    "tabs": {
      "category": "布局",
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": false,
      "supportsStates": false,
      "props": {
        "items": {
          "type": "array",
          "required": true,
          "description": "since 0.2：每项内嵌 content（完整 Node），不再依赖顶层 children 按 key 匹配",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string", "required": true },
              "label": { "type": "string" },
              "labelKey": { "type": "string" },
              "content": { "$ref": "node.schema.json", "description": "完整 Node" }
            },
            "required": ["key", "content"],
            "anyOf": [
              { "required": ["label"] },
              { "required": ["labelKey"] }
            ],
            "additionalProperties": false
          }
        },
        "span": { "type": "integer", "minimum": 1, "required": false, "since": "0.2" },
        "additionalProperties": false
      }
    },
    "statCard": {
      "category": "数据",
      "supportsChildren": false,
      "supportsData": true,
      "supportsReactions": false,
      "supportsStates": true,
      "props": {
        "label": { "type": "string", "required": false, "description": "卡片标题，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "unit": { "type": "string", "required": false },
        "format": { "type": "string", "enum": ["plain", "currency", "percent"], "required": false },
        "valueField": {
          "type": "string",
          "required": true,
          "since": "0.2",
          "description": "since 0.2：指定从 API 响应中取哪个字段作为展示值"
        },
        "span": { "type": "integer", "minimum": 1, "required": false, "since": "0.2" },
        "additionalProperties": false
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["labelKey"] }
      ]
    },
    "chart": {
      "category": "数据",
      "supportsChildren": false,
      "supportsData": true,
      "supportsReactions": false,
      "supportsStates": true,
      "props": {
        "chartType": { "type": "string", "enum": ["line", "bar", "pie"], "required": true },
        "xField": { "type": "string", "required": true },
        "yField": { "type": "string", "required": true },
        "span": { "type": "integer", "minimum": 1, "required": false, "since": "0.2" },
        "additionalProperties": false
      }
    },
    "text": {
      "category": "数据",
      "supportsChildren": false,
      "supportsData": true,
      "supportsReactions": false,
      "supportsStates": true,
      "props": {
        "content": { "type": "string", "required": false, "description": "静态文本内容；声明 data 时作为加载前/无数据时的兜底文案" },
        "contentKey": { "type": "string", "required": false },
        "valueField": {
          "type": "string",
          "required": false,
          "since": "0.2",
          "description": "since 0.2：data.source 为 api 时，指定取哪个字段作为展示文本。未指定时 Renderer 默认取响应体第一个字段值（与 statCard 保持一致的取值方式，但 statCard 的 valueField 为必填，text 为可选）"
        },
        "span": { "type": "integer", "minimum": 1, "required": false, "since": "0.2" },
        "additionalProperties": false
      },
      "anyOf": [
        { "required": ["content"] },
        { "required": ["contentKey"] }
      ]
    },
    "recordView": {
      "category": "数据",
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": false,
      "supportsStates": true,
      "props": {
        "title": { "type": "string", "required": false, "since": "2.4", "description": "详情区块标题" },
        "titleKey": { "type": "string", "required": false, "since": "2.4" },
        "recordSource": {
          "type": "object",
          "required": true,
          "since": "2.4",
          "description": "【ADR-0024】只读详情记录 GET 加载；使用时声明 record.view.load；形状与 form.recordSource 同构；responseMapping 必填非空。字段级 required 仅允许布尔（本字段 true=必填）；嵌套键 method/url/responseMapping 的必填由各自 properties.*.required 布尔表达，禁止在本对象上再写 required 数组以免覆盖字段级布尔（审计 0067 V302）",
          "properties": {
            "method": { "type": "string", "enum": ["GET"], "required": true },
            "url": { "type": "string", "required": true },
            "path": { "type": "object", "required": false },
            "query": { "type": "object", "required": false },
            "responseMapping": {
              "type": "object",
              "required": true,
              "description": "展示键 → 响应点路径；必填非空；fields[].key 必须是本对象的键",
              "minProperties": 1,
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "fields": {
          "type": "array",
          "required": true,
          "minItems": 1,
          "since": "2.4",
          "description": "只读字段表；每项 key 必须出现在 recordSource.responseMapping",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string", "minLength": 1, "required": true, "description": "展示键；对应 responseMapping 的键" },
              "label": { "type": "string" },
              "labelKey": { "type": "string" },
              "format": {
                "type": "string",
                "enum": ["plain", "currency", "datetime", "tag"],
                "required": false,
                "description": "展示格式；默认 plain；tag 时 tagMap 必填"
              },
              "tagMap": {
                "type": "object",
                "required": false,
                "description": "format: tag 时，值 → {text, tone} 的映射",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "tone": { "type": "string", "enum": ["warning", "success", "neutral", "info", "danger"] }
                  },
                  "required": ["text"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["key"],
            "anyOf": [
              { "required": ["label"] },
              { "required": ["labelKey"] }
            ],
            "additionalProperties": false
          }
        },
        "span": { "type": "integer", "minimum": 1, "required": false },
        "additionalProperties": false
      }
    },
    "table": {
      "category": "数据",
      "supportsChildren": false,
      "supportsData": true,
      "supportsReactions": false,
      "supportsStates": true,
      "props": {
        "title": { "type": "string", "required": false },
        "titleKey": { "type": "string", "required": false, "description": "表格标题 i18n key，可替代 title" },
        "rowKey": { "type": "string", "required": true },
        "pagination": {
          "type": "object",
          "required": true,
          "description": "分页配置",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["server", "client", "none"],
              "required": true,
              "description": "分页模式：server（服务端分页）/ client（客户端分页）/ none（不分页）"
            },
            "pageSize": {
              "type": "integer",
              "minimum": 1,
              "required": false,
              "description": "服务端分页模式下必填的页大小；client/none 模式不使用"
            }
          },
          "additionalProperties": false
        },
        "columns": {
          "type": "array",
          "required": true,
          "description": "列定义，与 docs/03-component-registry.md 中 ColumnDef 表格保持一致",
          "items": {
            "type": "object",
            "properties": {
              "field": { "type": "string", "description": "对应数据字段名" },
              "label": { "type": "string", "description": "列标题" },
              "format": { "type": "string", "enum": ["plain", "currency", "datetime", "tag"], "description": "展示格式" },
              "tagMap": {
                "type": "object",
                "description": "format: tag 时，值 → {text, tone} 的映射",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "tone": { "type": "string", "enum": ["warning", "success", "neutral", "info", "danger"] }
                  },
                  "required": ["text"],
                  "additionalProperties": false
                }
              },
              "labelKey": { "type": "string", "description": "列标题 i18n key（since 0.2）" },
              "visibleWhen": { "$ref": "node.schema.json#/definitions/VisibleWhen", "description": "列级条件渲染（since 0.2.1）" },
              "reactions": { "type": "array", "items": { "$ref": "reaction.schema.json" }, "description": "列级联动规则（since 0.2.1）" },
              "permissions": { "$ref": "node.schema.json#/definitions/Permissions", "description": "列级权限控制（since 0.2.1）；ADR-0023 中 columns[] 不参与 permissionCascade，且不允许 permissionIntent" }
            },
            "required": ["field"],
            "anyOf": [
              { "required": ["label"] },
              { "required": ["labelKey"] }
            ],
            "additionalProperties": false
          }
        },
        "actions": {
          "type": "array",
          "required": false,
          "description": "行内操作；key 仅供前端预注册处理器本地分发；actionRef 可引用顶层 request action 触发行级后端请求；可使用 visibleField 兼容语法糖或显式 visibleWhen 表达行级显隐",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string", "required": true },
              "actionRef": { "type": "string", "description": "【可选，since 0.2.7】引用顶层 actions 中 type:request 或 type:navigate 的 action；request 须声明 actions.row.request，navigate 须声明 actions.row.navigate（ADR-0021）" },
              "requestMapping": {
                "type": "object",
                "description": "【可选，since 0.2.7】RowAction 引用 type:request 时的参数绑定；path/query/body 均为非空 key 的扁平 map；值仅允许 string/finite number/boolean/null 或单个 $row.* 点路径；不得与 navigateMapping 同时出现",
                "properties": {
                  "path": { "type": "object" },
                  "query": { "type": "object" },
                  "body": { "type": "object" }
                },
                "additionalProperties": false
              },
              "navigateMapping": {
                "type": "object",
                "description": "【可选，since 2.1 / ADR-0021】RowAction 引用 type:navigate 时的 path/query 绑定；值仅允许字面量或单个 $row.*；不得声明 body；不得与 requestMapping 同时出现",
                "properties": {
                  "path": { "type": "object" },
                  "query": { "type": "object" }
                },
                "additionalProperties": false
              },
              "label": { "type": "string", "description": "操作文案，与 labelKey 至少提供一个" },
              "labelKey": { "type": "string", "description": "操作文案 i18n key，与 label 至少提供一个" },
              "confirm": { "type": "string" },
              "visibleField": {
                "type": "string",
                "since": "0.2",
                "description": "scope: row 的 visibleWhen 语法糖（since 0.2.1），解析阶段等价展开为 visibleWhen: { scope: row, dependencies: [<field>], when: \"$row.<field> == true\" }。与显式 visibleWhen 同时声明时以显式 visibleWhen 为准"
              },
              "visibleWhen": { "$ref": "node.schema.json#/definitions/VisibleWhen", "description": "行级操作条件渲染（since 0.2.1）" },
              "reactions": { "type": "array", "items": { "$ref": "reaction.schema.json" }, "description": "行级操作联动规则（since 0.2.1）" },
              "permissions": { "$ref": "node.schema.json#/definitions/Permissions", "description": "行级操作权限控制（since 0.2.1）" },
              "permissionIntent": { "type": "string", "enum": ["edit", "delete"], "since": "2.3", "description": "【ADR-0023】操作意图；声明后才参与祖先 permissionCascade 的同名 edit/delete 求值" }
            },
            "required": ["key"],
            "anyOf": [
              { "required": ["label"] },
              { "required": ["labelKey"] }
            ],
            "additionalProperties": false
          }
        },
        "selection": {
          "type": "object",
          "required": false,
          "since": "2.2",
          "description": "【ADR-0022】表格多选；使用时声明 table.selection。MVP 仅 mode:multiple，当前页选中，筛选/翻页/排序/reload 清空",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["multiple"],
              "required": true,
              "description": "MVP 仅 multiple"
            }
          },
          "required": ["mode"],
          "additionalProperties": false
        },
        "toolbar": {
          "type": "array",
          "required": false,
          "since": "2.1",
          "description": "【ADR-0020】表格工具栏 ActionTrigger 列表；使用时必须声明 meta.requiredCapabilities: [actions.page.trigger]。batchMapping/requiresSelection 见 ADR-0022",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string", "required": true },
              "label": { "type": "string" },
              "labelKey": { "type": "string" },
              "actionRef": { "type": "string", "required": true, "description": "引用顶层 request|navigate|modal action" },
              "confirm": { "type": "string" },
              "disabled": { "type": "boolean" },
              "requiresSelection": {
                "type": "boolean",
                "required": false,
                "since": "2.2",
                "description": "【ADR-0022】true 时选中数为 0 则 disabled；要求同 table 声明 selection"
              },
              "batchMapping": {
                "type": "object",
                "required": false,
                "since": "2.2",
                "description": "【ADR-0022】批量 request 绑定；body 值可为 $selection.keys；query 可为 $selection.count 或字面量；使用时声明 actions.batch.request",
                "properties": {
                  "path": { "type": "object" },
                  "query": { "type": "object" },
                  "body": { "type": "object" }
                },
                "additionalProperties": false
              },
              "visibleWhen": { "$ref": "node.schema.json#/definitions/VisibleWhen" },
              "permissions": { "$ref": "node.schema.json#/definitions/Permissions" },
              "permissionIntent": { "type": "string", "enum": ["edit", "delete"], "since": "2.3", "description": "【ADR-0023】操作意图；声明后才参与祖先 permissionCascade 的同名 edit/delete 求值" }
            },
            "required": ["key", "actionRef"],
            "anyOf": [
              { "required": ["label"] },
              { "required": ["labelKey"] }
            ],
            "additionalProperties": false
          }
        },
        "span": { "type": "integer", "minimum": 1, "required": false, "since": "0.2" },
        "additionalProperties": false
      }
    },
    "actionButton": {
      "category": "操作",
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": false,
      "supportsStates": false,
      "anyOf": [
        { "required": ["label"] },
        { "required": ["labelKey"] }
      ],
      "props": {
        "key": { "type": "string", "required": true, "since": "2.1", "description": "入口标识；不引用顶层 actions" },
        "label": { "type": "string" },
        "labelKey": { "type": "string" },
        "actionRef": { "type": "string", "required": true, "since": "2.1", "description": "引用顶层 request|navigate|modal；使用时声明 actions.page.trigger" },
        "confirm": { "type": "string", "required": false },
        "disabled": { "type": "boolean", "required": false },
        "permissionIntent": { "type": "string", "enum": ["edit", "delete"], "required": false, "since": "2.3", "description": "【ADR-0023】操作意图；actionButton 的 Node 级 permissions 仍在 props 外声明" },
        "span": { "type": "integer", "minimum": 1, "required": false },
        "additionalProperties": false
      }
    },
    "form": {
      "category": "表单",
      "supportsChildren": true,
      "supportsData": false,
      "supportsReactions": false,
      "supportsStates": false,
      "props": {
        "title": { "type": "string", "required": false },
        "titleKey": { "type": "string", "required": false },
        "submitAction": { "type": "string", "required": false, "description": "默认模式（mode=default）下必填，引用顶层 actions 中的动作 id；mode=search 时忽略此字段" },
        "mode": {
          "type": "string",
          "enum": ["default", "search"],
          "required": false,
          "since": "0.2.1",
          "description": "表单模式：default（提交动作）/ search（筛选表格）"
        },
        "targetTable": {
          "type": "string",
          "required": false,
          "since": "0.2.1",
          "description": "mode=search 时必填，关联表格的 Node id"
        },
        "recordSource": {
          "type": "object",
          "required": false,
          "since": "2.1",
          "description": "【ADR-0021】编辑表单记录 GET 加载；使用时声明 form.record.load；responseMapping 必填非空；search 模式禁止。字段级 required 仅允许布尔（本字段 false=可选）；嵌套键 method/url/responseMapping 的必填由各自 properties.*.required 布尔表达，禁止在本对象上再写 required 数组以免覆盖字段级布尔（审计 0067 V302）",
          "properties": {
            "method": { "type": "string", "enum": ["GET"], "required": true },
            "url": { "type": "string", "required": true },
            "path": { "type": "object", "required": false },
            "query": { "type": "object", "required": false },
            "responseMapping": {
              "type": "object",
              "required": true,
              "description": "form field → 响应点路径；必填非空",
              "minProperties": 1,
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "span": { "type": "integer", "minimum": 1, "required": false, "since": "0.2" },
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {
                "mode": { "const": "search" }
              },
              "required": ["mode"]
            },
            "then": {
              "required": ["targetTable"]
            },
            "else": {
              "required": ["submitAction"]
            }
          }
        ]
      }
    },
    "input": {
      "category": "表单",
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "minLength": 1, "required": true },
        "label": { "type": "string", "required": false, "description": "字段标签，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false },
        "placeholder": { "type": "string", "required": false, "since": "0.2" },
        "description": { "type": "string", "required": false, "since": "0.2" },
        "tooltip": { "type": "string", "required": false, "since": "0.2" },
        "span": { "type": "integer", "minimum": 1, "required": false, "since": "0.2" },
        "additionalProperties": false
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["labelKey"] }
      ]
    },
    "inputNumber": {
      "category": "表单",
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "minLength": 1, "required": true },
        "label": { "type": "string", "required": false, "description": "字段标签，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "min": { "type": "number", "required": false, "since": "0.2.1", "description": "最小值" },
        "max": { "type": "number", "required": false, "since": "0.2.1", "description": "最大值" },
        "step": { "type": "number", "required": false, "since": "0.2.1", "description": "步长" },
        "precision": { "type": "number", "required": false, "since": "0.2.1", "description": "保留小数位数" },
        "required": { "type": "boolean", "required": false },
        "defaultVisible": { "type": "boolean", "required": false },
        "placeholder": { "type": "string", "required": false, "since": "0.2" },
        "description": { "type": "string", "required": false, "since": "0.2" },
        "tooltip": { "type": "string", "required": false, "since": "0.2" },
        "span": { "type": "integer", "minimum": 1, "required": false, "since": "0.2" },
        "additionalProperties": false
      },
      "anyOf": [
        { "required": ["label"] },
        { "required": ["labelKey"] }
      ]
    },
    "datePicker": {
      "category": "表单",
      "supportsChildren": false,
      "supportsData": false,
      "supportsReactions": true,
      "supportsStates": false,
      "props": {
        "field": { "type": "string", "minLength": 1, "required": true },
        "label": { "type": "string", "required": false, "description": "字段标签，与 labelKey 至少提供一个" },
        "labelKey": { "type": "string", "required": false },
        "placeholder": { "type": "string", "required": false, "since": "0.2" },
        "description": { "type": "string", "required": false, "since": "0.2", "description": "字段说明文案" },
        "tooltip": { "type": "string", "required": false, "since": "0.2", "description": "悬浮提示文案" },
        "format": { "type": "string", "required": false, "description": "日期展示格式，仅控制前端展示；数据格式统一 ISO 8601" },
        "min": { "type": "string", "required": false, "description": "可选最小日期 ISO 8601" },
        "max": { "type": "string", "required": false, "description": "可选最大日期 ISO 8601" },
        "required": { "type": "boolean", "required": false },
