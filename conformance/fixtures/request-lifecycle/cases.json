{
  "fixtureVersion": "1.0",
  "category": "request-lifecycle",
  "cases": [
    {
      "id": "latest-generation-wins-over-old-response",
      "protocolVersion": "2.2",
      "category": "request-lifecycle",
      "input": {
        "initialState": "initial",
        "events": [
          {
            "type": "start"
          },
          {
            "type": "start"
          },
          {
            "type": "response",
            "generation": 1,
            "state": "old"
          },
          {
            "type": "response",
            "generation": 2,
            "state": "new"
          }
        ]
      },
      "expected": {
        "generation": 2,
        "active": true,
        "state": "new",
        "committed": [
          {
            "generation": 2,
            "state": "new"
          }
        ]
      }
    },
    {
      "id": "hidden-node-drops-response",
      "protocolVersion": "2.2",
      "category": "request-lifecycle",
      "input": {
        "initialState": "initial",
        "events": [
          {
            "type": "start"
          },
          {
            "type": "hide"
          },
          {
            "type": "response",
            "generation": 1,
            "state": "hidden-result"
          }
        ]
      },
      "expected": {
        "generation": 1,
        "active": false,
        "state": "initial",
        "committed": []
      }
    },
    {
      "id": "unmounted-node-drops-response",
      "protocolVersion": "2.2",
      "category": "request-lifecycle",
      "input": {
        "initialState": null,
        "events": [
          {
            "type": "unmount"
          },
          {
            "type": "response",
            "generation": 1,
            "state": "late"
          }
        ]
      },
      "expected": {
        "generation": 0,
        "active": false,
        "state": null,
        "committed": []
      }
    },
    {
      "id": "show-does-not-reactivate-hidden-request",
      "protocolVersion": "2.2",
      "category": "request-lifecycle",
      "input": {
        "initialState": "initial",
        "events": [
          {
            "type": "start"
          },
          {
            "type": "hide"
          },
          {
            "type": "show"
          },
          {
            "type": "response",
            "generation": 1,
            "state": "stale"
          }
        ]
      },
      "expected": {
        "generation": 1,
        "active": true,
        "state": "initial",
        "committed": []
      }
    }
  ]
}
