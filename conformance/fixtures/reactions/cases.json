    {
      "id": "loop-protection-stops-after-ten-rounds",
      "protocolVersion": "1.0",
      "category": "reactions",
      "input": {
        "initialValues": {
          "toggle": "a"
        },
        "maxRounds": 10,
        "fields": [
          {
            "field": "toggle",
            "reactions": [
              {
                "when": "$deps.toggle == 'a'",
                "fulfill": {
                  "value": "b"
                },
                "otherwise": {
                  "value": "a"
                }
              }
            ]
          }
        ],
        "observers": []
      },
      "expected": {
        "ok": false,
        "code": "REACTION_LOOP_LIMIT",
        "maxRounds": 10,
        "values": {
          "toggle": "a"
        },
        "roundCount": 10,
        "dependencyFields": [
          "toggle"
        ]
      }
    }
  ]
