    {
      "id": "baseline-restores-when-condition-becomes-false",
      "protocolVersion": "2.3",
      "category": "reactions",
      "input": {
        "initialValues": {
          "trigger": true,
          "status": "baseline"
        },
        "baselines": {
          "status": "baseline"
        },
        "fields": [
          {
            "field": "status",
            "reactions": [
              {
                "when": "$deps.trigger == true",
                "fulfill": {
                  "value": "active"
                }
              }
            ]
          }
        ],
        "observers": [
          {
            "id": "statusIsBaseline",
            "when": "$deps.status == 'baseline'"
          }
        ]
      },
      "expected": {
        "ok": true,
        "values": {
          "trigger": true,
          "status": "active"
        },
        "rounds": [
          {
            "round": 1,
            "snapshot": {
              "trigger": true,
              "status": "baseline"
            },
            "observations": {
              "statusIsBaseline": true
            },
            "commits": [
              {
                "field": "status",
                "value": "active"
              }
            ]
          },
          {
            "round": 2,
            "snapshot": {
              "trigger": true,
              "status": "active"
            },
            "observations": {
              "statusIsBaseline": false
            },
            "commits": []
          }
        ],
        "warnings": []
      }
