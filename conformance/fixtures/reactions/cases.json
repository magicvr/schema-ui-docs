    {
      "id": "strict-comparison-does-not-coerce-types",
      "protocolVersion": "2.3",
      "category": "reactions",
      "input": {
        "initialValues": {
          "count": 1,
          "label": "1",
          "enabled": true
        },
        "fields": [],
        "observers": [
          {
            "id": "numberEqualsNumber",
            "when": "$deps.count == 1.0"
          },
          {
            "id": "numberEqualsString",
            "when": "$deps.count == '1'"
          },
          {
            "id": "booleanEqualsNumber",
            "when": "$deps.enabled == 1"
          },
          {
            "id": "numberGreaterThanZero",
            "when": "$deps.count > 0"
          }
        ]
      },
      "expected": {
        "ok": true,
        "values": {
          "count": 1,
          "label": "1",
          "enabled": true
        },
        "rounds": [
          {
            "round": 1,
            "snapshot": {
              "count": 1,
              "label": "1",
              "enabled": true
            },
            "observations": {
              "numberEqualsNumber": true,
              "numberEqualsString": false,
              "booleanEqualsNumber": false,
              "numberGreaterThanZero": true
            },
            "commits": []
          }
        ],
        "warnings": []
      }
    },
