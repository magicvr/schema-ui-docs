{
  "fixtureVersion": "1.0",
  "category": "reactions",
  "cases": [
    {
      "id": "stable-snapshot-defers-dependent-visibility",
      "protocolVersion": "2.3",
      "category": "reactions",
      "input": {
        "initialValues": {
          "trigger": true,
          "status": "archived"
        },
        "fields": [
          {
            "field": "status",
            "reactions": [
              {
                "when": "$deps.trigger == true",
                "fulfill": {
                  "value": "closed"
                }
              }
            ]
          }
        ],
        "observers": [
          {
            "id": "closeReason",
            "when": "$deps.status == 'closed'"
          }
        ]
      },
      "expected": {
        "ok": true,
        "values": {
          "trigger": true,
          "status": "closed"
        },
        "rounds": [
          {
            "round": 1,
            "snapshot": {
              "trigger": true,
              "status": "archived"
            },
            "observations": {
              "closeReason": false
            },
            "commits": [
              {
                "field": "status",
                "value": "closed"
              }
            ]
          },
          {
            "round": 2,
            "snapshot": {
              "trigger": true,
              "status": "closed"
            },
            "observations": {
              "closeReason": true
            },
            "commits": []
          }
        ],
        "warnings": []
      }
    },
    {
      "id": "multiple-fields-commit-in-one-batch",
      "protocolVersion": "2.3",
      "category": "reactions",
      "input": {
        "initialValues": {
          "trigger": true,
          "first": "old-a",
          "second": "old-b"
        },
        "fields": [
          {
            "field": "first",
            "reactions": [
              {
                "when": "$deps.trigger == true",
                "fulfill": {
                  "value": "new-a"
                }
              }
            ]
          },
          {
            "field": "second",
            "reactions": [
              {
                "when": "$deps.trigger == true",
                "fulfill": {
                  "value": "new-b"
                }
              }
            ]
          }
        ],
        "observers": []
      },
      "expected": {
        "ok": true,
        "values": {
          "trigger": true,
          "first": "new-a",
          "second": "new-b"
        },
        "rounds": [
          {
            "round": 1,
            "snapshot": {
              "trigger": true,
              "first": "old-a",
              "second": "old-b"
            },
            "observations": {},
            "commits": [
              {
                "field": "first",
                "value": "new-a"
              },
              {
                "field": "second",
                "value": "new-b"
              }
            ]
          }
        ],
        "warnings": []
      }
    },
