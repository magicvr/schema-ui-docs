    {
      "id": "explicit-write-wins-over-implicit-baseline-reset",
      "protocolVersion": "2.3",
      "category": "reactions",
      "input": {
        "initialValues": {
          "keep": false,
          "reset": true,
          "status": "baseline"
        },
        "baselines": {
          "status": "baseline"
        },
        "externalUpdates": [
          {
            "afterRound": 1,
            "values": {
              "keep": true,
              "reset": false
            }
          }
        ],
        "fields": [
          {
            "field": "status",
            "reactions": [
              {
                "when": "$deps.keep == true",
                "fulfill": {
                  "value": "active"
                }
              },
              {
                "when": "$deps.reset == true",
                "fulfill": {
                  "value": "temporary"
                }
              }
            ]
          }
        ],
        "observers": []
      },
      "expected": {
        "ok": true,
        "values": {
          "keep": true,
          "reset": false,
          "status": "active"
        },
        "rounds": [
          {
            "round": 1,
            "snapshot": {
              "keep": false,
              "reset": true,
              "status": "baseline"
            },
            "observations": {},
            "commits": [
              {
                "field": "status",
                "value": "temporary"
              }
            ]
          },
          {
            "round": 2,
            "snapshot": {
              "keep": true,
              "reset": false,
              "status": "temporary"
            },
            "observations": {},
            "commits": [
              {
                "field": "status",
                "value": "active"
              }
            ]
          }
        ],
        "warnings": []
      }
    },
