{
  "fixtureVersion": "1.0",
  "category": "runtime-defaults",
  "cases": [
    {
      "id": "network-page-requires-base-url",
      "protocolVersion": "2.4",
      "category": "runtime-defaults",
      "input": {
        "kind": "requestConfig",
        "requiresNetwork": true
      },
      "expected": {
        "ok": false,
        "code": "MISSING_BASE_URL"
      }
    },
    {
      "id": "static-page-does-not-require-base-url",
      "protocolVersion": "2.4",
      "category": "runtime-defaults",
      "input": {
        "kind": "requestConfig",
        "requiresNetwork": false
      },
      "expected": {
        "ok": true
      }
    },
    {
      "id": "data-ref-method-default-materialized",
      "protocolVersion": "2.4",
      "category": "runtime-defaults",
      "input": {
        "kind": "defaults",
        "target": "dataRef",
        "value": {
          "url": "/orders"
        }
      },
      "expected": {
        "ok": true,
        "value": {
          "url": "/orders",
          "method": "GET"
        }
      }
    },
    {
      "id": "upload-defaults-materialized",
      "protocolVersion": "2.4",
      "category": "runtime-defaults",
      "input": {
        "kind": "defaults",
        "target": "uploadAction",
        "value": {
          "url": "/upload"
        }
      },
      "expected": {
        "ok": true,
        "value": {
          "url": "/upload",
          "method": "POST",
          "retryPolicy": "never",
          "fieldName": "file",
          "multiple": false
        }
      }
    },
    {
      "id": "missing-required-prop-is-invalid-component",
      "protocolVersion": "2.4",
      "category": "runtime-defaults",
      "input": {
        "kind": "component",
        "type": "statCard",
        "installedTypes": [
          "statCard"
        ],
        "requiredProps": [
          "label",
          "valueField"
        ],
        "props": {
          "label": "Orders"
        }
      },
      "expected": {
        "ok": false,
        "code": "INVALID_COMPONENT",
        "path": "props.valueField"
      }
    },
    {
      "id": "uninstalled-extension-is-unknown-component",
      "protocolVersion": "2.4",
      "category": "runtime-defaults",
      "input": {
        "kind": "component",
        "type": "vendor.auditWidget",
        "installedTypes": [
          "table"
        ],
        "requiredProps": [],
        "props": {}
      },
      "expected": {
        "ok": false,
        "code": "UNKNOWN_COMPONENT_TYPE"
      }
    }
  ]
}
