      },
      "expected": {
        "state": {
          "filters": {
            "keyword": "invoice"
          },
          "page": 5,
          "pageSize": 20,
          "sort": "amount:desc"
        },
        "url": "/orders?keyword=invoice&page=5&pageSize=20&sort=amount%3Adesc"
      }
    },
    {
      "id": "sort-change-resets-page-and-keeps-filters",
      "protocolVersion": "2.3",
      "category": "search-table",
      "input": {
        "baseUrl": "/orders",
        "staticParams": {},
        "state": {
          "filters": {
            "keyword": "invoice"
          },
          "page": 5,
          "pageSize": 20,
          "sort": "amount:desc"
