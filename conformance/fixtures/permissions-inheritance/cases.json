    {
      "id": "missing-source-and-forbidden-intent-mounts-fail-closed",
      "protocolVersion": "2.4",
      "category": "permissions-inheritance",
      "input": {
        "page": {
          "meta": { "protocolVersion": "2.4", "requiredCapabilities": ["permissions.inheritance"] },
