          { "targetId": "editForm:submit", "kind": "formSubmit", "key": "edit", "cascadeApplied": true, "cascadedBy": ["root"], "effectivePermission": true },
          { "targetId": "name", "kind": "formField", "key": "edit", "cascadeApplied": true, "cascadedBy": ["root"], "effectivePermission": false }
        ]
      }
    },
    {
      "id": "table-actions-toolbar-inherit-columns-stay-local",
      "protocolVersion": "2.4",
      "category": "permissions-inheritance",
      "input": {
        "page": {
          "meta": { "protocolVersion": "2.4", "requiredCapabilities": ["permissions.inheritance"] },
          "body": {
            "type": "table",
            "id": "orders",
            "permissions": { "delete": false },
            "permissionCascade": { "keys": ["delete"] },
            "props": {
              "columns": [
                { "field": "orderNo", "permissions": { "view": true } }
              ],
              "actions": [
                { "key": "delete", "permissionIntent": "delete", "permissions": { "delete": true } },
                { "key": "localOnly", "permissions": { "delete": true } }
              ],
              "toolbar": [
                { "key": "deleteAll", "permissionIntent": "delete", "permissions": { "delete": true } }
              ]
            }
          }
        }
      },
      "expected": {
        "validation": { "valid": true, "errors": [] },
        "targets": [
          { "targetId": "orderNo", "kind": "column", "key": "view", "cascadeApplied": false, "cascadedBy": [], "effectivePermission": true },
          { "targetId": "delete", "kind": "rowAction", "key": "delete", "cascadeApplied": true, "cascadedBy": ["orders"], "effectivePermission": false },
          { "targetId": "localOnly", "kind": "rowAction", "key": "delete", "cascadeApplied": false, "cascadedBy": [], "effectivePermission": true },
          { "targetId": "deleteAll", "kind": "toolbarTrigger", "key": "delete", "cascadeApplied": true, "cascadedBy": ["orders"], "effectivePermission": false }
        ]
      }
    },
    {
      "id": "tabs-content-is-a-cascade-edge",
      "protocolVersion": "2.4",
