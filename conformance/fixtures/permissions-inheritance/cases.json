          { "targetId": "email", "kind": "formField", "key": "edit", "cascadeApplied": true, "cascadedBy": ["accessTabs"], "effectivePermission": false }
        ]
      }
    },
    {
      "id": "modal-and-navigated-pages-start-new-roots",
      "protocolVersion": "2.4",
      "category": "permissions-inheritance",
      "input": {
        "page": {
          "meta": { "protocolVersion": "2.4", "requiredCapabilities": ["permissions.inheritance"] },
          "actions": {
            "editModal": {
              "type": "modal",
              "content": {
                "type": "form",
                "id": "modalForm",
                "props": { "submitAction": "saveModal" },
                "children": [
                  { "type": "input", "props": { "field": "modalName" } }
                ]
              }
            }
          },
          "body": {
            "type": "section",
            "id": "guarded",
            "permissions": { "edit": false },
            "permissionCascade": { "keys": ["edit"] },
            "children": [
              { "type": "actionButton", "props": { "key": "openModal", "permissionIntent": "edit" } }
            ]
          }
        },
        "navigatedPage": {
          "body": {
            "type": "form",
            "id": "navigatedForm",
            "props": { "submitAction": "savePage" },
            "children": [
              { "type": "input", "props": { "field": "pageName" } }
            ]
          }
        }
      },
      "expected": {
        "validation": { "valid": true, "errors": [] },
        "targets": [
          { "targetId": "openModal", "kind": "actionButton", "key": "edit", "cascadeApplied": true, "cascadedBy": ["guarded"], "effectivePermission": false },
          { "targetId": "modalForm:submit", "kind": "formSubmit", "key": "edit", "cascadeApplied": false, "cascadedBy": [], "effectivePermission": true },
          { "targetId": "modalName", "kind": "formField", "key": "edit", "cascadeApplied": false, "cascadedBy": [], "effectivePermission": true },
          { "targetId": "navigatedForm:submit", "kind": "formSubmit", "key": "edit", "cascadeApplied": false, "cascadedBy": [], "effectivePermission": true },
          { "targetId": "pageName", "kind": "formField", "key": "edit", "cascadeApplied": false, "cascadedBy": [], "effectivePermission": true }
        ]
      }
    },
