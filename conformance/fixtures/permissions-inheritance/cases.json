{
  "fixtureVersion": "1.0",
  "category": "permissions-inheritance",
  "cases": [
    {
      "id": "nested-ancestor-and-form-local-tightens",
      "protocolVersion": "2.4",
      "category": "permissions-inheritance",
      "input": {
        "page": {
          "meta": { "protocolVersion": "2.4", "requiredCapabilities": ["permissions.inheritance"] },
          "body": {
            "type": "section",
            "id": "root",
            "permissions": { "edit": true },
            "permissionCascade": { "keys": ["edit"] },
            "children": [
              {
                "type": "form",
                "id": "editForm",
                "permissions": { "edit": false },
                "permissionCascade": { "keys": ["edit"] },
                "props": { "submitAction": "save" },
                "children": [
                  { "type": "input", "permissions": { "edit": true }, "props": { "field": "name" } }
                ]
              }
            ]
          }
        }
      },
      "expected": {
        "validation": { "valid": true, "errors": [] },
        "targets": [
          { "targetId": "editForm:submit", "kind": "formSubmit", "key": "edit", "cascadeApplied": true, "cascadedBy": ["root", "editForm"], "effectivePermission": false },
          { "targetId": "name", "kind": "formField", "key": "edit", "cascadeApplied": true, "cascadedBy": ["root", "editForm"], "effectivePermission": false }
        ]
      }
    },
    {
      "id": "local-permission-cannot-loosen-ancestor",
