        "dataRef": {
          "source": "api",
          "url": "https://api.example.com/orders"
        }
      },
      "expected": {
        "ok": false,
        "code": "INVALID_PROTOCOL_URL",
        "path": "dataRef.url"
      }
    },
    {
      "id": "form-action-absolute-url-rejected",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "formAction",
        "action": {
          "method": "POST",
          "url": "https://api.example.com/orders"
        },
        "formValues": {}
      },
      "expected": {
        "ok": false,
        "code": "INVALID_PROTOCOL_URL",
        "path": "action.url"
      }
    },
    {
      "id": "form-action-invalid-retry-policy-rejected",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "formAction",
        "action": {
          "method": "POST",
          "url": "/orders",
          "retryPolicy": "always"
        },
        "formValues": {}
      },
      "expected": {
        "ok": false,
        "code": "INVALID_RETRY_POLICY",
        "path": "action.retryPolicy"
      }
    }
  ]
}
