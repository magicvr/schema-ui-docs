    {
      "id": "form-action-projection-excludes-hidden-disabled-upload-error",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "formAction",
        "action": {
          "method": "POST",
          "url": "/orders",
          "bodyMapping": {
            "visible": "visible"
          }
        },
        "formValues": {
          "visible": "ok",
          "hidden": "old",
          "disabled": "old",
          "upload": "partial"
        },
        "formProjection": {
          "visible": { "value": "ok" },
          "hidden": { "value": "old", "visible": false },
          "disabled": { "value": "old", "disabled": true },
          "upload": { "value": "partial", "uploadStatus": "error" }
        }
      },
      "expected": {
        "ok": true,
        "request": {
          "method": "POST",
          "url": "/orders",
          "body": {
            "visible": "ok"
          }
        }
      }
    },
    {
      "id": "data-ref-interceptor-cannot-change-query",
