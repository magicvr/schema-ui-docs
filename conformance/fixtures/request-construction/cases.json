    {
      "id": "row-action-inherits-idempotency-policy",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "rowAction",
        "action": {
          "method": "POST",
          "url": "/orders/{id}/approve",
          "retryPolicy": "idempotent"
        },
        "requestMapping": {
          "path": {
            "id": "$row.id"
          }
        },
        "row": {
          "id": 42
        },
        "invocationId": "row-inv-001"
      },
      "expected": {
        "ok": true,
        "request": {
          "method": "POST",
          "url": "/orders/42/approve",
          "body": null,
          "headers": {
            "Idempotency-Key": "row-inv-001"
          }
        }
      }
    },
    {
      "id": "form-action-idempotency-header",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "formAction",
        "action": {
          "method": "POST",
          "url": "/orders",
          "retryPolicy": "idempotent"
        },
        "invocationId": "inv-001",
        "formValues": {
          "name": "A"
        }
      },
      "expected": {
        "ok": true,
        "request": {
          "method": "POST",
          "url": "/orders",
          "body": {
            "name": "A"
          },
          "headers": {
            "Idempotency-Key": "inv-001"
          }
        }
      }
    },
