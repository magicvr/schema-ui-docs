    {
      "id": "form-action-default-projection-omits-missing-value",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "formAction",
        "action": { "method": "POST", "url": "/orders" },
        "formProjection": {
          "present": { "value": "ok" },
          "missing": {}
        }
      },
      "expected": {
        "ok": true,
        "request": {
          "method": "POST",
          "url": "/orders",
          "body": { "present": "ok" }
        }
      }
    }
