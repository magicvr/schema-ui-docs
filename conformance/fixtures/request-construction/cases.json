{
  "fixtureVersion": "1.0",
  "category": "request-construction",
  "cases": [
    {
      "id": "data-ref-default-get",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "dataRef",
        "dataRef": {
          "source": "api",
          "url": "/orders",
          "params": {
            "status": "paid"
          }
        }
      },
      "expected": {
        "ok": true,
        "request": {
          "method": "GET",
          "url": "/orders?status=paid",
          "body": null
        }
      }
    },
    {
      "id": "data-ref-post-rejected",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "dataRef",
        "dataRef": {
          "source": "api",
          "method": "POST",
          "url": "/reports?locale=zh-CN",
          "params": {
            "keyword": "new value",
            "empty": null
          }
        }
      },
      "expected": {
        "ok": false,
        "code": "DATA_REF_METHOD_NOT_READ_ONLY",
        "path": "dataRef.method"
      }
    },
    {
      "id": "row-action-path-query-body",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "rowAction",
        "action": {
          "method": "PATCH",
          "url": "/orders/{orderId}?locale=zh-CN"
        },
        "requestMapping": {
          "path": {
            "orderId": "$row.order.id"
          },
          "query": {
            "source": "table",
            "version": "$row.version"
          },
          "body": {
            "approved": true,
            "decision": "$row.decision"
          }
        },
        "row": {
          "order": {
            "id": "A/B 1"
          },
          "version": 3,
          "decision": "APPROVED"
        }
      },
      "expected": {
        "ok": true,
        "request": {
          "method": "PATCH",
          "url": "/orders/A%2FB%201?locale=zh-CN&source=table&version=3",
          "body": {
            "approved": true,
            "decision": "APPROVED"
          }
        }
      }
    },
    {
      "id": "row-action-delete-with-query",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "rowAction",
        "action": {
          "method": "DELETE",
          "url": "/orders/{id}"
        },
        "requestMapping": {
          "path": {
            "id": "$row.id"
          },
          "query": {
            "hard": false
          }
        },
        "row": {
          "id": 42
        }
      },
      "expected": {
        "ok": true,
        "request": {
          "method": "DELETE",
          "url": "/orders/42?hard=false",
          "body": null
        }
      }
    },
    {
      "id": "row-action-path-rfc3986-encoding",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "rowAction",
        "action": {
          "method": "GET",
          "url": "/items/{id}"
        },
        "requestMapping": {
          "path": {
            "id": "$row.id"
          }
        },
        "row": {
          "id": "!*'()~"
        }
      },
      "expected": {
        "ok": true,
        "request": {
          "method": "GET",
          "url": "/items/%21%2A%27%28%29~",
          "body": null
        }
      }
    },
    {
      "id": "row-action-missing-row-path",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "rowAction",
        "action": {
          "method": "POST",
          "url": "/orders/{id}/approve"
        },
        "requestMapping": {
          "path": {
            "id": "$row.missing"
          }
        },
        "row": {
          "id": 42
        }
      },
      "expected": {
        "ok": false,
        "code": "UNRESOLVED_ROW_VALUE",
        "path": "requestMapping.path.id"
      }
    },
    {
      "id": "row-action-null-path",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "rowAction",
        "action": {
          "method": "POST",
          "url": "/orders/{id}/approve"
        },
        "requestMapping": {
          "path": {
            "id": "$row.id"
          }
        },
        "row": {
          "id": null
        }
      },
      "expected": {
        "ok": false,
        "code": "NULL_PATH_VALUE",
        "path": "requestMapping.path.id"
      }
    },
    {
      "id": "row-action-nested-body-rejected",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "rowAction",
        "action": {
          "method": "POST",
          "url": "/orders"
        },
        "requestMapping": {
          "body": {
            "payload": "$row.profile"
          }
        },
        "row": {
          "profile": {
            "id": 1
          }
        }
      },
      "expected": {
        "ok": false,
        "code": "INVALID_ROW_VALUE",
        "path": "requestMapping.body.payload"
      }
    },
    {
      "id": "row-action-prototype-path-rejected",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "rowAction",
        "action": {
          "method": "POST",
          "url": "/orders"
        },
        "requestMapping": {
          "body": {
            "payload": "$row.__proto__"
          }
        },
        "row": {}
      },
      "expected": {
        "ok": false,
        "code": "UNSAFE_ROW_PATH",
        "path": "requestMapping.body.payload"
      }
    },
    {
      "id": "form-action-idempotency-header",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "formAction",
        "action": {
          "method": "POST",
          "url": "/orders",
          "retryPolicy": "idempotent"
        },
        "invocationId": "inv-001",
        "formValues": {
          "name": "A"
        }
      },
      "expected": {
        "ok": true,
        "request": {
          "method": "POST",
          "url": "/orders",
          "body": {
            "name": "A"
          },
          "headers": {
            "Idempotency-Key": "inv-001"
          }
        }
      }
    },
    {
      "id": "form-action-idempotency-requires-invocation-id",
      "protocolVersion": "2.0",
      "category": "request-construction",
      "input": {
        "kind": "formAction",
        "action": {
          "method": "POST",
          "url": "/orders",
          "retryPolicy": "idempotent"
        },
        "formValues": {
          "name": "A"
        }
      },
      "expected": {
        "ok": false,
        "code": "MISSING_INVOCATION_ID",
        "path": "invocationId"
      }
    },
    {
      "id": "data-ref-absolute-url-rejected",
      "protocolVersion": "2.0",
