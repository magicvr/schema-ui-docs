    {
      "id": "form-record-explicit-mapping",
      "protocolVersion": "2.2",
      "category": "response-mapping",
      "input": {
        "component": "formRecord",
        "responseMapping": {
          "orderId": "orderId",
          "customerName": "customer.name",
          "version": "version"
        },
        "response": {
          "orderId": "ORD-1",
          "customer": {
            "name": "Ada"
          },
          "version": 3,
          "extra": "ignored"
        }
      },
      "expected": {
        "ok": true,
        "values": {
          "orderId": "ORD-1",
          "customerName": "Ada",
          "version": 3
        }
      }
    },
    {
      "id": "form-record-missing-path-becomes-null",
      "protocolVersion": "2.2",
      "category": "response-mapping",
      "input": {
        "component": "formRecord",
        "responseMapping": {
          "orderId": "orderId",
          "missing": "not.there"
        },
        "response": {
          "orderId": "ORD-2"
        }
      },
      "expected": {
        "ok": true,
        "values": {
          "orderId": "ORD-2",
          "missing": null
        }
      }
    },
