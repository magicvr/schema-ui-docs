    {
      "id": "official-row-backend-actions",
      "protocolVersion": "0.3",
      "category": "scenarios",
      "input": {
        "scenarioPath": "docs/05-scenarios/row-backend-actions.md",
        "scenarioMeta": { "pageId": "order_operations", "protocolVersion": "0.3" },
        "steps": [
          {
            "kind": "request",
            "input": {
              "kind": "rowAction",
              "action": { "method": "POST", "url": "/api/orders/{orderId}/refund" },
              "requestMapping": {
                "path": { "orderId": "$row.orderId" },
                "body": { "amount": "$row.refundableAmount", "source": "order_list" }
              },
              "row": { "orderId": "1001", "refundableAmount": 199.5 }
            }
          },
          {
            "kind": "action",
            "input": {
              "transport": { "type": "success", "status": 200 },
              "onSuccess": { "behavior": "reload" },
              "context": { "tableId": "order_table" }
            }
          }
        ]
      },
      "expected": {
        "pageId": "order_operations",
        "protocolVersion": "0.3",
        "steps": [
          {
            "ok": true,
            "request": {
              "method": "POST",
              "url": "/api/orders/1001/refund",
              "body": { "amount": 199.5, "source": "order_list" }
            }
          },
          {
            "ok": true,
            "events": [
              { "type": "requestSucceeded", "status": 200 },
              { "type": "reloadTable", "tableId": "order_table" }
            ]
          }
        ]
      }
    },
