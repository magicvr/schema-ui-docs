    {
      "id": "official-form-with-upload",
      "protocolVersion": "0.3",
      "category": "scenarios",
      "input": {
        "scenarioPath": "docs/05-scenarios/form-with-upload.md",
        "scenarioMeta": { "pageId": "contract_upload", "protocolVersion": "0.3" },
        "steps": [
          {
            "kind": "upload",
            "input": {
              "action": { "url": "/api/files/upload", "method": "POST", "fieldName": "file", "multiple": true },
              "files": [
                { "name": "contract.pdf", "type": "application/pdf", "size": 100, "contentId": "contract" },
                { "name": "appendix.docx", "type": "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "size": 120, "contentId": "appendix" }
              ],
              "results": [
                { "type": "success", "response": { "url": "https://cdn/contract.pdf" } },
                { "type": "success", "response": { "id": "appendix-id" } }
              ]
            }
          },
          {
            "kind": "request",
            "input": {
              "kind": "formAction",
              "action": { "method": "POST", "url": "/api/contracts" },
              "formValues": { "title": "采购合同", "attachments": ["https://cdn/contract.pdf", "appendix-id"] }
            }
          }
        ]
      },
      "expected": {
        "pageId": "contract_upload",
        "protocolVersion": "0.3",
        "steps": [
          {
            "ok": true,
            "requests": [
              { "method": "POST", "url": "/api/files/upload", "part": { "name": "file", "fileName": "contract.pdf", "contentId": "contract" } },
              { "method": "POST", "url": "/api/files/upload", "part": { "name": "file", "fileName": "appendix.docx", "contentId": "appendix" } }
            ],
            "fieldValue": ["https://cdn/contract.pdf", "appendix-id"]
          },
          {
            "ok": true,
            "request": {
              "method": "POST",
              "url": "/api/contracts",
              "body": { "title": "采购合同", "attachments": ["https://cdn/contract.pdf", "appendix-id"] }
            }
          }
        ]
      }
