{
  "fixtureVersion": "1.0",
  "category": "uploads",
  "cases": [
    {
      "id": "single-file-defaults-and-url-priority",
      "protocolVersion": "2.2",
      "category": "uploads",
      "input": {
        "action": {
          "url": "/files"
        },
        "files": [
          {
            "name": "contract.pdf",
            "type": "application/pdf",
            "size": 100,
            "contentId": "file-a"
          }
        ],
        "results": [
          {
            "type": "success",
            "response": {
              "url": "https://cdn/a.pdf",
              "id": "id-a"
            }
          }
        ]
      },
      "expected": {
        "ok": true,
        "requests": [
          {
            "method": "POST",
            "url": "/files",
            "part": {
              "name": "file",
              "fileName": "contract.pdf",
              "contentId": "file-a"
            }
          }
        ],
        "fieldValue": "https://cdn/a.pdf"
      }
    },
    {
      "id": "single-file-id-fallback-and-custom-request",
      "protocolVersion": "2.2",
      "category": "uploads",
      "input": {
        "action": {
          "url": "/assets",
          "method": "PUT",
          "fieldName": "asset"
        },
        "files": [
          {
            "name": "logo.png",
            "type": "image/png",
            "size": 200,
            "contentId": "file-b"
          }
        ],
        "results": [
          {
            "type": "success",
            "response": {
              "id": "asset-1"
            }
          }
        ]
      },
      "expected": {
        "ok": true,
        "requests": [
          {
            "method": "PUT",
            "url": "/assets",
            "part": {
              "name": "asset",
              "fileName": "logo.png",
              "contentId": "file-b"
            }
          }
        ],
        "fieldValue": "asset-1"
      }
    },
    {
      "id": "multiple-files-preserve-selection-order",
      "protocolVersion": "2.2",
      "category": "uploads",
      "input": {
        "action": {
          "url": "/files",
          "multiple": true
        },
        "files": [
          {
            "name": "first.pdf",
            "type": "application/pdf",
            "size": 100,
            "contentId": "first"
          },
          {
            "name": "second.pdf",
            "type": "application/pdf",
            "size": 120,
            "contentId": "second"
          }
        ],
        "results": [
          {
            "type": "success",
            "response": {
              "id": "first-id"
            }
          },
          {
            "type": "success",
            "response": {
              "url": "https://cdn/second.pdf"
            }
          }
        ]
      },
      "expected": {
        "ok": true,
        "requests": [
          {
            "method": "POST",
            "url": "/files",
            "part": {
              "name": "file",
              "fileName": "first.pdf",
              "contentId": "first"
            }
          },
          {
            "method": "POST",
            "url": "/files",
            "part": {
              "name": "file",
              "fileName": "second.pdf",
              "contentId": "second"
            }
          }
        ],
        "fieldValue": [
          "first-id",
          "https://cdn/second.pdf"
        ]
      }
    },
