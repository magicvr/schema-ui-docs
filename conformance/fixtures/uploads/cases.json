    {
      "id": "multiple-request-failure-stops-and-is-atomic",
      "protocolVersion": "2.2",
      "category": "uploads",
      "input": {
        "action": {
          "url": "/files",
          "multiple": true
        },
        "files": [
          {
            "name": "a.pdf",
            "type": "application/pdf",
            "size": 100,
            "contentId": "a"
          },
          {
            "name": "b.pdf",
            "type": "application/pdf",
            "size": 100,
            "contentId": "b"
          },
          {
            "name": "c.pdf",
            "type": "application/pdf",
            "size": 100,
            "contentId": "c"
          }
        ],
        "results": [
          {
            "type": "success",
            "response": {
              "id": "a-id"
            }
          },
          {
            "type": "failure",
            "status": 503
          },
          {
            "type": "success",
            "response": {
              "id": "c-id"
            }
          }
        ]
      },
      "expected": {
        "ok": false,
        "code": "UPLOAD_REQUEST_FAILED",
        "fileIndex": 1,
        "requests": [
          {
            "method": "POST",
            "url": "/files",
            "part": {
              "name": "file",
              "fileName": "a.pdf",
              "contentId": "a"
            }
          },
          {
            "method": "POST",
            "url": "/files",
            "part": {
              "name": "file",
              "fileName": "b.pdf",
              "contentId": "b"
            }
          }
        ],
        "fieldValue": null
      }
    },
    {
      "id": "idempotent-upload-uses-file-key",
      "protocolVersion": "2.2",
      "category": "uploads",
      "input": {
        "action": {
          "url": "/files",
          "retryPolicy": "idempotent"
        },
        "invocationId": "upload-001",
        "files": [
          {
            "name": "a.pdf",
            "type": "application/pdf",
            "size": 100,
            "contentId": "a"
          }
        ],
        "results": [
          {
            "type": "success",
            "response": {
              "id": "a-id"
            }
          }
        ]
      },
      "expected": {
        "ok": true,
        "requests": [
          {
            "method": "POST",
            "url": "/files",
            "part": {
              "name": "file",
              "fileName": "a.pdf",
              "contentId": "a"
            },
            "headers": {
              "Idempotency-Key": "upload-001:0"
            }
          }
        ],
        "fieldValue": "a-id"
      }
    },
