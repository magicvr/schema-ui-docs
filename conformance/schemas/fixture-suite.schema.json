{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema-ui.dev/conformance/fixture-suite.schema.json",
  "title": "Schema-UI Conformance Fixture Suite",
  "type": "object",
  "required": ["fixtureVersion", "category", "cases"],
  "properties": {
    "fixtureVersion": {
      "const": "1.0"
    },
    "category": {
      "type": "string",
      "enum": [
        "request-construction",
        "response-mapping",
        "search-table",
        "reactions",
        "actions",
        "errors",
        "uploads",
        "scenarios"
      ]
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "protocolVersion", "category", "input", "expected"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "protocolVersion": {
            "type": "string",
            "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"
          },
          "category": {
            "type": "string"
          },
          "input": {
            "type": "object"
          },
          "expected": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}